---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import Button from "../ui/Button.astro";
import Input from "../ui/Input.astro";
import { Icon } from "astro-icon/components";
import { site } from "../../content/site";

const mailto = `mailto:${site.email}?subject=Contato%20pelo%20portf%C3%B3lio`;
---

<section
  id="contato"
  class="scroll-mt-20 bg-background py-20 md:py-28 lg:py-32"
  aria-labelledby="contact-heading"
>
  <Container>
    <div
      class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between lg:gap-16"
    >
      <div class="max-w-2xl lg:max-w-none lg:flex-1">
        <Reveal staggerMs={0}>
          <AccentBar class="mb-8" />
          <h2
            id="contact-heading"
            class="font-display text-3xl font-semibold leading-tight tracking-[-0.04em] text-foreground sm:text-4xl md:text-5xl lg:text-6xl"
          >
            Contato
          </h2>
          <p
            class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground md:text-sm md:tracking-[0.15em]"
          >
            Propostas, parcerias ou conversa técnica
          </p>
        </Reveal>
      </div>
      <Reveal staggerMs={120} class="shrink-0 lg:max-w-md">
        <p
          class="text-base leading-[1.6] text-muted-foreground md:text-lg md:leading-relaxed"
        >
          Use o formulário, o e-mail ou as redes. Para vagas, inclua a descrição
          ou o link do LinkedIn; costumo responder em até um dia útil.
        </p>
      </Reveal>
    </div>

    <div class="grid grid-cols-1 gap-16 pt-16 lg:grid-cols-12 lg:gap-12">
      <div class="lg:col-span-7">
        <Reveal staggerMs={80}>
          <form
            id="contact-form"
            class="relative space-y-8 border border-border bg-card p-6 md:p-8"
          >
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              class="absolute size-px overflow-hidden opacity-0"
            />
            <input type="hidden" name="_ts" value="" data-contact-ts />
            <Input
              id="c-name"
              name="name"
              label="Nome"
              placeholder="Como posso te chamar"
              required
            />
            <Input
              id="c-email"
              name="email"
              type="email"
              label="E-mail"
              placeholder="voce@email.com"
              required
            />
            <Input
              id="c-message"
              name="message"
              label="Mensagem"
              placeholder="Diga como posso ajudar seu time ou empresa..."
              rows={5}
              required
            />
            <Button type="submit" variant="secondary" class="min-h-12 w-full">
              <span data-contact-submit-label>Enviar mensagem</span>
            </Button>
            <span
              id="contact-form-status"
              class="hidden font-mono"
              role="status"
              aria-live="polite"
            >
            </span>
          </form>
          <script src="../../scripts/contact-form.ts"></script>
        </Reveal>
      </div>

      <aside class="lg:col-span-5">
        <Reveal staggerMs={160}>
          <div class="border border-border bg-card p-6 md:p-8">
            <h3
              class="font-mono text-xs font-medium uppercase tracking-[0.15em] text-muted-foreground"
            >
              Email
            </h3>
            <a
              href={mailto}
              class="mt-4 block font-display text-xl font-semibold tracking-[-0.03em] text-accent underline decoration-2 underline-offset-[6px] transition-colors duration-150 hover:text-foreground focus-ring"
            >
              {site.email}
            </a>

            <div class="mt-8 border-t border-border pt-8">
              <p
                class="font-mono text-xs font-medium uppercase tracking-[0.15em] text-muted-foreground"
              >
                Currículo
              </p>
              <a
                href={site.resumePdfUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex min-h-14 w-full items-center justify-center gap-3 border border-foreground px-6 py-4 font-semibold uppercase tracking-[0.1em] text-foreground transition-all duration-150 ease-[cubic-bezier(0.25,0,0,1)] hover:bg-foreground hover:text-background focus-ring active:translate-y-px md:min-h-16"
              >
                <svg
                  class="size-6 shrink-0 md:size-7"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                  ></path>
                  <path d="M14 2v6h6"></path>
                  <path d="M10 13h4"></path>
                  <path d="M10 17h4"></path>
                </svg>
                Ver currículo
              </a>
            </div>
            <nav
              class="mt-8 border-t border-border pt-8"
              aria-label="Redes sociais"
            >
              <p
                class="font-mono text-xs font-medium uppercase tracking-[0.15em] text-muted-foreground"
              >
                Redes
              </p>
              <div class="mt-4 flex flex-col gap-3">
                <a
                  href={site.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-14 w-full items-center justify-center gap-3 border border-foreground px-6 py-4 font-semibold uppercase tracking-[0.1em] text-foreground transition-all duration-150 ease-[cubic-bezier(0.25,0,0,1)] hover:bg-foreground hover:text-background focus-ring active:translate-y-px md:min-h-16"
                >
                  <Icon
                    name="simple-icons:github"
                    class="size-6 shrink-0 md:size-7"
                  />
                  GitHub
                </a>
                <a
                  href={site.linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-14 w-full items-center justify-center gap-3 border border-foreground px-6 py-4 font-semibold uppercase tracking-[0.1em] text-foreground transition-all duration-150 ease-[cubic-bezier(0.25,0,0,1)] hover:bg-foreground hover:text-background focus-ring active:translate-y-px md:min-h-16"
                >
                  <Icon
                    name="simple-icons:linkedin"
                    class="size-6 shrink-0 md:size-7"
                  />
                  LinkedIn
                </a>
              </div>
            </nav>
          </div>
        </Reveal>
      </aside>
    </div>
  </Container>
</section>

<section
  class="border-t border-border bg-foreground py-24 text-background md:py-32 lg:py-40"
  aria-labelledby="cta-heading"
>
  <Container>
    <Reveal staggerMs={0}>
      <AccentBar class="mb-8" />
      <h2
        id="cta-heading"
        class="font-display max-w-3xl text-3xl font-semibold leading-[1.1] tracking-[-0.04em] sm:text-4xl md:text-5xl lg:text-6xl"
      >
        {site.contactCta.title}
      </h2>
      <p
        class="mt-6 max-w-xl text-base leading-relaxed text-background/70 md:text-lg"
      >
        {site.contactCta.body}
      </p>
      <div
        class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8"
      >
        <Button href={site.linkedinUrl} variant="primary" showArrow>
          Conectar no LinkedIn
        </Button>
        <Button
          href={site.resumePdfUrl}
          variant="ghost"
          onLight
          class="justify-center"
        >
          Baixar Currículo (PDF)
        </Button>
      </div>
    </Reveal>
  </Container>
</section>
