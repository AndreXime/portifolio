---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import Button from "../ui/Button.astro";
import Input from "../ui/Input.astro";
import { Icon } from "astro-icon/components";
import type { PageContext } from "../../i18n/context";

type Props = PageContext;

const { ui, site } = Astro.props;

const mailto = `mailto:${site.email}?subject=${encodeURIComponent(ui.contact.mailSubject)}`;
---

<section
  id="contato"
  class="scroll-mt-20 border-b border-border bg-background py-16 md:py-20 lg:py-24"
  aria-labelledby="contact-heading"
>
  <Container>
    <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-12 lg:gap-10">
      <Reveal staggerMs={0} class="lg:col-span-5">
        <AccentBar class="mb-6" />
        <h2
          id="contact-heading"
          class="font-display text-3xl font-semibold leading-tight tracking-tight text-foreground sm:text-4xl md:text-5xl"
        >
          {ui.contact.title}
        </h2>
        <p
          class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
        >
          {ui.contact.subtitle}
        </p>
      </Reveal>
      <Reveal staggerMs={80} class="flex items-center lg:col-span-7">
        <p class="text-base leading-[1.7] text-foreground-variant md:text-lg">
          {ui.contact.intro}
        </p>
      </Reveal>
    </div>

    <div
      class="mt-14 grid grid-cols-1 gap-8 border-t border-border pt-14 lg:grid-cols-12 lg:gap-10"
    >
      <div class="lg:col-span-7">
        <Reveal staggerMs={100}>
          <form
            id="contact-form"
            class="card-hover-bordered group/card relative space-y-6 p-6 md:p-8"
            data-msg-error-generic={ui.contact.errorGeneric}
            data-msg-error-fast={ui.contact.errorTooFast}
            data-msg-error-network={ui.contact.errorNetwork}
            data-msg-success={ui.contact.success}
            data-msg-submitting={ui.contact.submitting}
          >
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
              class="absolute size-px overflow-hidden opacity-0"
            />
            <input type="hidden" name="_ts" value="" data-contact-ts />
            <Input
              id="c-name"
              name="name"
              label={ui.contact.name}
              placeholder={ui.contact.namePlaceholder}
              required
            />
            <Input
              id="c-email"
              name="email"
              type="email"
              label={ui.contact.email}
              placeholder={ui.contact.emailPlaceholder}
              required
            />
            <Input
              id="c-message"
              name="message"
              label={ui.contact.message}
              placeholder={ui.contact.messagePlaceholder}
              rows={5}
              required
            />
            <Button type="submit" variant="primary" class="min-h-12 w-full">
              <span data-contact-submit-label>{ui.contact.submit}</span>
            </Button>
            <span
              id="contact-form-status"
              class="hidden font-mono text-sm"
              role="status"
              aria-live="polite"
            >
            </span>
          </form>
        </Reveal>
      </div>

      <aside class="lg:col-span-5">
        <Reveal staggerMs={140}>
          <div class="card-hover-bordered group/card divide-y divide-border">
            <div class="p-6 md:p-8">
              <h3
                class="font-mono text-xs font-medium uppercase tracking-[0.12em] text-muted-foreground"
              >
                {ui.contact.emailHeading}
              </h3>
              <a
                href={mailto}
                class="mt-3 block font-display text-xl font-semibold text-accent underline decoration-accent/40 decoration-1 underline-offset-[6px] transition-colors duration-150 hover:decoration-accent focus-ring"
              >
                {site.email}
              </a>
            </div>

            <div class="p-6 md:p-8">
              <p
                class="font-mono text-xs font-medium uppercase tracking-[0.12em] text-muted-foreground"
              >
                {ui.contact.resumeHeading}
              </p>
              <a
                href={site.resumePdfUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex min-h-12 w-full items-center justify-center gap-3 border border-foreground px-5 py-3 font-mono text-xs font-medium uppercase tracking-[0.12em] text-foreground transition-colors duration-150 hover:bg-foreground hover:text-background focus-ring active:translate-y-px"
              >
                <svg
                  class="size-5 shrink-0"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.75"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path
                    d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                  ></path>
                  <path d="M14 2v6h6"></path>
                  <path d="M10 13h4"></path>
                  <path d="M10 17h4"></path>
                </svg>
                {ui.contact.resumeCta}
              </a>
            </div>

            <nav class="p-6 md:p-8" aria-label={ui.contact.socialAria}>
              <p
                class="font-mono text-xs font-medium uppercase tracking-[0.12em] text-muted-foreground"
              >
                {ui.contact.socialHeading}
              </p>
              <div class="mt-4 flex flex-col gap-3">
                <a
                  href={site.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-12 w-full items-center justify-center gap-3 border border-foreground px-5 py-3 font-mono text-xs font-medium uppercase tracking-[0.12em] text-foreground transition-colors duration-150 hover:bg-foreground hover:text-background focus-ring active:translate-y-px"
                >
                  <Icon name="simple-icons:github" class="size-5 shrink-0" />
                  GitHub
                </a>
                <a
                  href={site.linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-12 w-full items-center justify-center gap-3 border border-foreground px-5 py-3 font-mono text-xs font-medium uppercase tracking-[0.12em] text-foreground transition-colors duration-150 hover:bg-foreground hover:text-background focus-ring active:translate-y-px"
                >
                  <Icon name="simple-icons:linkedin" class="size-5 shrink-0" />
                  LinkedIn
                </a>
              </div>
            </nav>
          </div>
        </Reveal>
      </aside>
    </div>
  </Container>
</section>
