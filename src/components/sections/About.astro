---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import type { PageContext } from "../../i18n/context";

type Props = PageContext;

const { ui, site } = Astro.props;
---

<section
  id="sobre"
  class="scroll-mt-20 border-b border-border bg-muted py-16 md:py-20 lg:py-24"
  aria-labelledby="about-heading"
>
  <Container>
    <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-12 lg:gap-12">
      <Reveal staggerMs={0} class="lg:col-span-4">
        <AccentBar class="mb-6" />
        <h2
          id="about-heading"
          class="font-display text-3xl font-semibold leading-tight tracking-tight text-foreground sm:text-4xl md:text-5xl"
        >
          {ui.about.title}
        </h2>
        <p
          class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
        >
          {ui.about.subtitle}
        </p>
      </Reveal>

      <Reveal staggerMs={80} class="flex items-center lg:col-span-8">
        <blockquote
          class="border-l-2 border-accent pl-5 font-display text-xl font-semibold leading-snug text-foreground md:text-2xl"
        >
          &ldquo;{site.about.quote}&rdquo;
        </blockquote>
      </Reveal>
    </div>

    <div
      class="mt-14 grid grid-cols-1 gap-10 border-t border-border pt-14 lg:grid-cols-12 lg:gap-12"
    >
      <Reveal staggerMs={100} class="lg:col-span-4">
        <figure
          class="card-hover-bordered group/card mx-auto w-full max-w-72 p-2 sm:max-w-80 lg:mx-0 lg:max-w-none"
        >
          <img
            src="/me.webp"
            alt={site.about.photoAlt}
            width={424}
            height={424}
            class="aspect-square w-full object-cover object-center"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </Reveal>

      <Reveal staggerMs={140} class="lg:col-span-8">
        <div class="space-y-6 text-base leading-[1.7] md:text-lg">
          {
            site.about.paragraphs.map((paragraph, index) => (
              <p
                class:list={[
                  index === 0 ? "text-foreground" : "text-foreground-variant",
                ]}
                set:html={paragraph}
              />
            ))
          }
        </div>
      </Reveal>
    </div>
  </Container>
</section>
