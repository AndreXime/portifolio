---
import { Icon } from "astro-icon/components";
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import type { TechnologyList } from "../../lib/content";
import { getPageContext } from "../../lib/i18n/context";

interface Props {
  technologies: TechnologyList;
}

const { ui } = await getPageContext(Astro.currentLocale);
const { technologies } = Astro.props;

const LOCAL_ICONS = new Set(["bullmq", "shadcn", "rest"]);

function resolveIconName(slug: string) {
  return LOCAL_ICONS.has(slug) ? slug : `simple-icons:${slug}`;
}
---

<section
  id="tecnologias"
  class="scroll-mt-20 border-b border-border bg-background py-16 md:py-20 lg:py-24"
  aria-labelledby="tech-heading"
>
  <Container>
    <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-12 lg:gap-10">
      <Reveal staggerMs={0} class="lg:col-span-5">
        <AccentBar class="mb-6" />
        <h2
          id="tech-heading"
          class="font-display text-3xl font-semibold leading-tight tracking-tight text-foreground sm:text-4xl md:text-5xl"
        >
          {ui.technologies.title}
        </h2>
        <p
          class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
        >
          {ui.technologies.subtitle}
        </p>
      </Reveal>
      <Reveal staggerMs={80} class="flex items-center lg:col-span-7">
        <p class="text-base leading-[1.7] text-foreground-variant md:text-lg">
          {ui.technologies.intro}
        </p>
      </Reveal>
    </div>

    <ul
      class="mt-14 grid list-none grid-cols-1 gap-px border border-border bg-border sm:grid-cols-2 lg:mt-16 lg:grid-cols-3"
    >
      {
        technologies.map((item, index) => (
          <li class="bg-background">
            <Reveal staggerMs={Math.min(index * 40, 280)}>
              <article
                class="card-hover-flat group/card flex h-full flex-col p-6 md:p-7"
                aria-label={item.name}
              >
                <p class="font-mono text-xs font-medium uppercase tracking-[0.12em] text-muted-foreground">
                  {item.role}
                </p>
                <h3 class="card-hover-title mt-3 font-display text-lg font-semibold leading-snug text-foreground md:text-xl">
                  {item.name}
                </h3>
                <ul
                  class="mt-6 flex list-none flex-wrap gap-3 border-t border-border pt-6"
                  aria-label={`Ícones de ${item.name}`}
                >
                  {item.icons.map((slug) => (
                    <li>
                      <span
                        class="tech-logo inline-flex size-8 items-center justify-center border border-border bg-card text-foreground transition-colors duration-150 hover:border-accent hover:bg-accent/5 hover:text-accent md:size-9"
                        aria-hidden="true"
                      >
                        <Icon
                          name={resolveIconName(slug)}
                          class="size-4 md:size-5"
                        />
                      </span>
                    </li>
                  ))}
                </ul>
              </article>
            </Reveal>
          </li>
        ))
      }
    </ul>
  </Container>
</section>

<style is:global>
  .tech-logo svg {
    max-height: 100%;
    max-width: 100%;
  }

  .tech-logo svg,
  .tech-logo svg :where(path, circle, rect, polygon) {
    fill: currentColor;
  }

  .tech-logo svg :where(line, polyline) {
    stroke: currentColor;
  }
</style>
