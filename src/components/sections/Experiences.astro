---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import { Image } from "astro:assets";
import type { ExperienceList } from "../../content/index";
import type { PageContext } from "../../i18n/context";

interface Props extends PageContext {
  experiences: ExperienceList;
}

const { ui, site, experiences } = Astro.props;
---

<section
  id="experiencias"
  class="scroll-mt-20 border-b border-border bg-background py-16 md:py-20 lg:py-24"
  aria-labelledby="exp-heading"
>
  <Container>
    <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-12 lg:gap-10">
      <Reveal staggerMs={0} class="lg:col-span-5">
        <AccentBar class="mb-6" />
        <h2
          id="exp-heading"
          class="font-display text-3xl font-semibold leading-tight tracking-tight text-foreground sm:text-4xl md:text-5xl"
        >
          {ui.experiences.title}
        </h2>
        <p
          class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
        >
          {ui.experiences.subtitle}
        </p>
      </Reveal>
      <Reveal staggerMs={80} class="flex items-center lg:col-span-7">
        <p class="text-base leading-[1.7] text-foreground-variant md:text-lg">
          {site.sections.experiencesIntro}
        </p>
      </Reveal>
    </div>

    <ul class="mt-14 list-none border-t border-border lg:mt-16">
      {
        experiences.map((exp, index) => (
          <li class="border-b border-border last:border-b-0">
            <Reveal staggerMs={index * 60}>
              <article class="card-hover-flat group/card grid grid-cols-1 gap-6 px-4 py-8 md:px-6 md:py-10 lg:grid-cols-12 lg:gap-8">
                <header class="flex gap-4 lg:col-span-4">
                  {exp.logo && (
                    <div class="flex size-14 shrink-0 items-center justify-center border border-border bg-card transition-colors duration-150 group-hover/card:border-accent sm:size-16">
                      <Image
                        src={exp.logo}
                        alt={`Logo ${exp.company}`}
                        width={64}
                        height={64}
                        sizes="64px"
                        class="max-h-11 max-w-11 object-contain p-1.5 sm:max-h-12 sm:max-w-12"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="min-w-0">
                    <h3 class="card-hover-title font-display text-xl font-semibold leading-tight text-foreground md:text-2xl">
                      {exp.role}
                    </h3>
                    <p class="mt-1 font-mono text-sm font-medium text-accent">
                      {exp.company}
                    </p>
                    <p class="mt-2 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground">
                      {exp.period}
                    </p>
                  </div>
                </header>

                <div class="min-w-0 lg:col-span-8">
                  <p class="text-base leading-[1.7] text-foreground-variant md:text-lg">
                    {exp.summary}
                  </p>
                  {exp.highlights && exp.highlights.length > 0 && (
                    <ul
                      class="mt-6 list-disc space-y-3 border-t border-border pt-6 pl-5 text-sm leading-relaxed text-foreground-variant md:text-base"
                      aria-label={ui.experiences.highlightsAria.replace(
                        "{company}",
                        exp.company,
                      )}
                    >
                      {exp.highlights.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            </Reveal>
          </li>
        ))
      }
    </ul>
  </Container>
</section>
