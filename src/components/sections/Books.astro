---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import { books } from "../../data/books";

const BOOKS_INITIAL = 2;

function stateClass(state: (typeof books)[number]["state"]): string {
  switch (state) {
    case "Lido":
      return "border-accent/50 text-accent";
    case "Lendo atualmente":
      return "border-foreground/30 text-foreground";
    case "Na lista de desejos":
      return "border-border text-muted-foreground";
  }
}
---

<section
  id="livros"
  class="scroll-mt-20 border-b border-border bg-muted py-20 md:py-28 lg:py-32"
  aria-labelledby="books-heading"
>
  <Container>
    <Reveal staggerMs={0}>
      <AccentBar class="mb-8" />
      <h2
        id="books-heading"
        class="font-display text-3xl font-semibold leading-tight tracking-[-0.04em] text-foreground sm:text-4xl md:text-5xl"
      >
        Livros técnicos
      </h2>
      <p
        class="mt-4 max-w-xl font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
      >
        Leituras, em andamento e próximas metas
      </p>
    </Reveal>

    <ul id="livros-list" class="mt-16 list-none space-y-6 lg:mt-20">
      {
        books.map((book, index) => {
          const src = book.imageUrl.startsWith("/")
            ? book.imageUrl
            : `/${book.imageUrl.replace(/^\//, "")}`;
          const isExtra = index >= BOOKS_INITIAL;
          return (
            <li
              class:list={[isExtra && "hidden"]}
              data-book-extra={isExtra ? "" : undefined}
            >
              <Reveal staggerMs={index * 70}>
                <article class="rounded-xl border border-border bg-background p-6 md:p-8">
                  <div class="flex flex-col gap-6 sm:flex-row sm:gap-8 lg:gap-10">
                    <div class="mx-auto shrink-0 sm:mx-0">
                      <div class="w-36 overflow-hidden rounded-md border border-neutral-200 bg-white shadow-sm sm:w-40">
                        <img
                          src={src}
                          alt={`Capa: ${book.title}`}
                          width="160"
                          height="240"
                          class="aspect-[2/3] w-full object-cover object-top"
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="flex flex-wrap items-start gap-2 gap-y-2">
                        <span
                          class:list={[
                            "inline-flex border px-2 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-[0.1em]",
                            stateClass(book.state),
                          ]}
                        >
                          {book.state}
                        </span>
                        <span class="inline-flex border border-border bg-background px-2 py-0.5 font-mono text-[10px] font-medium uppercase tracking-[0.1em] text-muted-foreground">
                          {book.tag}
                        </span>
                      </div>
                      <h3 class="font-display mt-4 text-xl font-semibold leading-tight tracking-[-0.03em] text-foreground md:text-2xl">
                        {book.title}
                      </h3>
                      <p class="mt-1 font-mono text-sm text-accent md:text-base">
                        {book.author}
                      </p>
                      {book.review && (
                        <p class="mt-4 text-base leading-[1.6] text-muted-foreground md:text-lg md:leading-relaxed">
                          {book.review}
                        </p>
                      )}
                    </div>
                  </div>
                </article>
              </Reveal>
            </li>
          );
        })
      }
    </ul>

    {
      books.length > BOOKS_INITIAL && (
        <div class="mt-10 flex justify-center border-t border-border pt-10">
          <button
            type="button"
            id="books-show-more"
            class="inline-flex items-center justify-center border border-foreground px-6 py-3 font-semibold uppercase tracking-[0.1em] text-foreground transition-colors duration-150 ease-[cubic-bezier(0.25,0,0,1)] hover:bg-foreground hover:text-background focus-ring active:translate-y-px"
          >
            Ver mais
          </button>
        </div>
      )
    }
  </Container>
</section>

<script>
  function setupBooksShowMore() {
    const btn = document.getElementById("books-show-more");
    const list = document.getElementById("livros-list");
    if (!btn || !list) return;
    if (btn.dataset.ready === "1") return;
    btn.dataset.ready = "1";

    btn.addEventListener("click", () => {
      const extras = list.querySelectorAll("li[data-book-extra]");
      extras.forEach((li) => {
        li.classList.remove("hidden");
        li.querySelectorAll("[data-reveal-root]").forEach((node) => {
          node.classList.add("is-visible");
        });
      });
      btn.closest("div")?.remove();
    });
  }

  setupBooksShowMore();
  document.addEventListener("astro:page-load", setupBooksShowMore);
</script>
