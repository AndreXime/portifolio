---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import Button from "../ui/Button.astro";
import type { ProjectEntry } from "../../content/index";
import {
  getProjectPagePath,
  getProjectsIndexPath,
  projectImageAlt,
} from "../../lib/project-page";
import { getDominantColor } from "../../lib/dominant-color";
import type { PageContext } from "../../i18n/context";
import { Image } from "astro:assets";

interface Props extends PageContext {
  projects: ProjectEntry[];
}

const { locale, ui, site, projects: projectEntries } = Astro.props;

const PROJECTS_HOME_GRID = 2;
const featuredProject = projectEntries[0] ?? null;
const gridProjects = projectEntries.slice(1, 1 + PROJECTS_HOME_GRID);
const projectsIndexHref = getProjectsIndexPath(locale);

const featuredLandscapeColor = featuredProject
  ? await getDominantColor(featuredProject.data.imageUrl)
  : null;
const [featuredPortraitColor, gridProjectsWithColor] = await Promise.all([
  featuredProject?.data.featuredImageUrl != null
    ? getDominantColor(featuredProject.data.featuredImageUrl)
    : Promise.resolve(featuredLandscapeColor),
  Promise.all(
    gridProjects.map(async (project) => ({
      project,
      dominantColor: await getDominantColor(project.data.imageUrl),
    })),
  ),
]);
---

<section
  id="projetos"
  class="scroll-mt-20 border-b border-border bg-muted py-16 md:py-20 lg:py-24"
  aria-labelledby="projects-heading"
>
  <Container>
    <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-12 lg:gap-10">
      <Reveal staggerMs={0} class="lg:col-span-5">
        <AccentBar class="mb-6" />
        <h2
          id="projects-heading"
          class="font-display text-3xl font-semibold leading-tight tracking-tight text-foreground sm:text-4xl md:text-5xl"
        >
          {ui.projects.title}
        </h2>
        <p
          class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
        >
          {ui.projects.subtitle}
        </p>
      </Reveal>
      <Reveal staggerMs={80} class="flex items-center lg:col-span-7">
        <p class="text-base leading-[1.7] text-foreground-variant md:text-lg">
          {site.sections.projectsSubtitle}{" "}
          <a
            href={site.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline decoration-accent/40 decoration-1 underline-offset-4 transition-colors duration-150 hover:decoration-accent focus-ring"
          >
            {ui.projects.githubCta}
          </a>
        </p>
      </Reveal>
    </div>

    {
      featuredProject && featuredLandscapeColor && (
        <div class="mt-14 lg:mt-16">
          <Reveal staggerMs={0}>
            <article class="card-hover-bordered group/card grid grid-cols-1 lg:grid-cols-[16rem_1fr]">
              <div class="relative aspect-video overflow-hidden border-b border-border lg:aspect-auto lg:flex lg:min-h-[20rem] lg:items-stretch lg:justify-center lg:border-b-0 lg:border-r">
                {featuredProject.data.featuredImageUrl && featuredPortraitColor ? (
                  <>
                    <div
                      class="h-full w-full lg:hidden"
                      style={`background-color: ${featuredLandscapeColor}`}
                    >
                      <Image
                        src={featuredProject.data.imageUrl}
                        alt={projectImageAlt(featuredProject, ui.projectPage.imageAlt)}
                        width={featuredProject.data.imageUrl.width}
                        height={featuredProject.data.imageUrl.height}
                        widths={[400, 640, 800]}
                        sizes="(max-width: 639px) calc(100vw - 2.5rem), (max-width: 1023px) calc(100vw - 5rem), 0px"
                        class="h-full w-full object-contain"
                        loading="eager"
                        decoding="async"
                      />
                    </div>
                    <div
                      class="hidden h-full w-full lg:block"
                      style={`background-color: ${featuredPortraitColor}`}
                    >
                      <Image
                        src={featuredProject.data.featuredImageUrl}
                        alt={projectImageAlt(featuredProject, ui.projectPage.imageAlt)}
                        width={featuredProject.data.featuredImageUrl.width}
                        height={featuredProject.data.featuredImageUrl.height}
                        widths={[256, 512]}
                        sizes="(min-width: 1024px) 16rem, 0"
                        class="h-full max-h-full w-full object-contain"
                        loading="eager"
                        decoding="async"
                      />
                    </div>
                  </>
                ) : (
                  <div
                    class="h-full w-full"
                    style={`background-color: ${featuredLandscapeColor}`}
                  >
                    <Image
                      src={featuredProject.data.imageUrl}
                      alt={projectImageAlt(featuredProject, ui.projectPage.imageAlt)}
                      width={featuredProject.data.imageUrl.width}
                      height={featuredProject.data.imageUrl.height}
                      sizes="(max-width: 1024px) 100vw, 16rem"
                      class="h-full w-full object-contain"
                      loading="eager"
                      decoding="async"
                    />
                  </div>
                )}
              </div>
              <div class="flex flex-col p-6 md:p-8">
                <h3 class="card-hover-title font-display text-xl font-semibold text-foreground md:text-2xl">
                  <a
                    href={getProjectPagePath(featuredProject.slug, locale)}
                    class="transition-colors duration-150 hover:text-accent focus-ring"
                  >
                    {featuredProject.data.title}
                  </a>
                </h3>
                <p class="mt-4 flex-1 text-sm leading-relaxed text-foreground-variant md:text-base">
                  {featuredProject.data.shortDescription}
                </p>
                <ul
                  class="mt-6 flex flex-wrap gap-2 border-t border-border pt-6"
                  aria-label={ui.projects.stackAria}
                >
                  {featuredProject.data.tech.map((t) => (
                    <li class="border border-border px-2 py-1 font-mono text-[10px] uppercase tracking-[0.08em] text-muted-foreground">
                      {t}
                    </li>
                  ))}
                </ul>
                <div class="mt-6">
                  <Button
                    href={getProjectPagePath(featuredProject.slug, locale)}
                    variant="secondary"
                    showArrow
                    class="w-full justify-center"
                  >
                    {ui.projects.viewDetails}
                  </Button>
                </div>
              </div>
            </article>
          </Reveal>
        </div>
      )
    }

    <ul
      class:list={[
        "list-none grid grid-cols-1 gap-6 sm:grid-cols-2 lg:gap-8",
        featuredProject ? "mt-8" : "mt-14 lg:mt-16",
      ]}
    >
      {
        gridProjectsWithColor.map(({ project, dominantColor }, index) => (
          <li class="min-h-0 h-full">
            <Reveal staggerMs={index * 60} class="h-full min-h-0">
              <article class="card-hover-bordered group/card flex h-full flex-col">
                <a
                  href={getProjectPagePath(project.slug, locale)}
                  class="relative block aspect-video overflow-hidden border-b border-border"
                  style={`background-color: ${dominantColor}`}
                >
                  <Image
                    src={project.data.imageUrl}
                    alt={projectImageAlt(project, ui.projectPage.imageAlt)}
                    width={project.data.imageUrl.width}
                    height={project.data.imageUrl.height}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 40vw"
                    class="h-full w-full object-contain"
                    loading="lazy"
                    decoding="async"
                  />
                </a>
                <div class="flex flex-1 flex-col p-6 md:p-8">
                  <h3 class="card-hover-title font-display text-xl font-semibold text-foreground">
                    <a
                      href={getProjectPagePath(project.slug, locale)}
                      class="transition-colors duration-150 hover:text-accent focus-ring"
                    >
                      {project.data.title}
                    </a>
                  </h3>
                  <p class="mt-4 flex-1 text-sm leading-relaxed text-foreground-variant md:text-base">
                    {project.data.shortDescription}
                  </p>
                  <ul
                    class="mt-6 flex flex-wrap gap-2 border-t border-border pt-6"
                    aria-label={ui.projects.stackAria}
                  >
                    {project.data.tech.map((t) => (
                      <li class="border border-border px-2 py-1 font-mono text-[10px] uppercase tracking-[0.08em] text-muted-foreground">
                        {t}
                      </li>
                    ))}
                  </ul>
                  <div class="mt-6">
                    <Button
                      href={getProjectPagePath(project.slug, locale)}
                      variant="secondary"
                      showArrow
                      class="w-full justify-center"
                    >
                      {ui.projects.viewDetails}
                    </Button>
                  </div>
                </div>
              </article>
            </Reveal>
          </li>
        ))
      }
    </ul>

    <div class="mt-10 flex justify-center border-t border-border pt-10">
      <Button href={projectsIndexHref} variant="secondary" showArrow>
        {ui.projects.viewAll}
      </Button>
    </div>
  </Container>
</section>
