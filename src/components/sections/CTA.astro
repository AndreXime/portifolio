---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import Button from "../ui/Button.astro";
import type { PageContext } from "../../i18n/context";

type Props = PageContext;

const { ui, site } = Astro.props;
---

<section
  id="cta"
  class="scroll-mt-20 border-b border-accent bg-accent py-16 text-accent-foreground md:py-20 lg:py-24"
  aria-labelledby="cta-heading"
>
  <Container>
    <Reveal staggerMs={0}>
      <AccentBar class="bg-accent-foreground" />
      <h2
        id="cta-heading"
        class="font-display mt-6 max-w-3xl text-2xl font-semibold leading-tight tracking-tight sm:text-3xl md:text-4xl"
      >
        {site.cta.title}
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-[1.7] text-accent-foreground/90 md:text-lg">
        {site.cta.body}
      </p>
      <div
        class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center"
      >
        <Button href={site.linkedinUrl} variant="primary" showArrow onLight>
          {ui.cta.linkedin}
        </Button>
        <Button href={site.resumePdfUrl} variant="secondary" onLight>
          {ui.cta.resume}
        </Button>
      </div>
    </Reveal>
  </Container>
</section>
