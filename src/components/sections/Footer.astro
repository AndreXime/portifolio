---
import { Icon } from "astro-icon/components";
import Container from "../ui/Container.astro";
import type { PageContext } from "../../lib/i18n/context";
import { homeHash } from "../../lib/i18n/paths";

type Props = PageContext;

const { locale, ui, site } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-muted py-10 md:py-12">
  <Container>
    <div
      class="grid grid-cols-1 gap-8 border border-border bg-card p-6 md:grid-cols-[1fr_auto] md:items-center md:p-8"
    >
      <div>
        <p
          class="font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
        >
          {ui.footer.portfolioPrefix} {site.authorName}
        </p>
        <p class="mt-2 font-display text-lg font-semibold text-foreground">
          {site.person.jobTitle}
        </p>
        <p class="mt-1 text-sm text-muted-foreground">
          &copy; {year}. {ui.footer.tagline}
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-6">
        <a
          href={site.blogUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors duration-150 hover:text-accent focus-ring"
          aria-label="Blog"
        >
          <Icon name="blog" class="h-[23px] w-auto" />
        </a>
        <a
          href={site.githubUrl}
          target="_blank"
          rel="me noopener noreferrer"
          class="text-muted-foreground transition-colors duration-150 hover:text-accent focus-ring"
          aria-label="GitHub"
        >
          <Icon name="simple-icons:github" class="size-[23px]" />
        </a>
        <a
          href={site.linkedinUrl}
          target="_blank"
          rel="me noopener noreferrer"
          class="text-muted-foreground transition-colors duration-150 hover:text-foreground focus-ring"
          aria-label="LinkedIn"
        >
          <Icon name="simple-icons:linkedin" class="size-[23px]" />
        </a>
        <a
          href={homeHash(locale, "inicio")}
          class="cursor-pointer font-mono text-sm uppercase tracking-[0.12em] text-muted-foreground underline decoration-border decoration-1 underline-offset-4 transition-colors duration-150 hover:text-accent hover:decoration-accent focus-ring"
        >
          {ui.footer.backToTop}
        </a>
      </div>
    </div>
  </Container>
</footer>
