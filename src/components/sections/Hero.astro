---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import { site } from "../../data/site";
---

<section
  id="inicio"
  class="border-b border-border bg-background py-20 md:py-28 lg:py-40"
  aria-labelledby="hero-heading"
>
  <Container class="relative">
    <Reveal staggerMs={100}>
      <AccentBar class="mb-8 md:mb-10" />
      <h1
        id="hero-heading"
        class="font-display max-w-[18ch] text-5xl font-semibold leading-[1.05] tracking-[-0.06em] text-foreground md:text-6xl lg:text-7xl xl:text-8xl"
      >
        Construindo sistemas com
        <span class="text-accent">clareza</span>
        e escala.
      </h1>

      <p
        class="mt-8 max-w-2xl text-base leading-[1.75] text-muted-foreground md:text-lg md:leading-relaxed"
      >
        Olá, meu nome é <span class="font-bold text-accent"
          >{site.authorName}</span
        >. Sou desenvolvedor de software especializado em ecossistema
        TypeScript. Meu foco é traduzir regras de negócio em código
        auto-documentado, criando APIs estáveis e interfaces que evoluem sem
        medo de refatoração. <span class="font-bold text-accent"
          >Atualmente buscando novos desafios em times de engenharia.</span
        >
      </p>

      <div
        class="mt-12 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:gap-8"
      >
        <Button href="#projetos" variant="primary" showArrow>
          Ver projetos
        </Button>
        <Button href="#contato" variant="secondary"> Entrar em contato </Button>
      </div>
    </Reveal>

    <dl
      class="mt-20 grid grid-cols-1 gap-10 border-t border-border pt-12 sm:grid-cols-2 md:grid-cols-3 md:gap-8"
    >
      <Reveal staggerMs={0}>
        <dt
          class="font-mono text-sm uppercase tracking-[0.15em] text-muted-foreground"
        >
          Stack
        </dt>
        <dd class="mt-2 font-mono text-sm text-foreground">
          TS · Hono · React
        </dd>
      </Reveal>
      <Reveal staggerMs={80}>
        <dt
          class="font-mono text-sm uppercase tracking-[0.15em] text-muted-foreground"
        >
          Experiência
        </dt>
        <dd class="mt-2 font-mono text-sm text-foreground">6 meses</dd>
      </Reveal>
      <Reveal staggerMs={240}>
        <dt
          class="font-mono text-sm uppercase tracking-[0.15em] text-muted-foreground"
        >
          Localização
        </dt>
        <dd class="mt-2 font-mono text-sm text-foreground">Remoto · BR</dd>
      </Reveal>
    </dl>
  </Container>
</section>
