---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import { formations } from "../../data/formations";
---

<section
  id="formacoes"
  class="scroll-mt-20 border-b border-border bg-muted py-20 md:py-28 lg:py-32"
  aria-labelledby="form-heading"
>
  <Container>
    <Reveal staggerMs={0}>
      <AccentBar class="mb-8" />
      <h2
        id="form-heading"
        class="font-display text-3xl font-semibold leading-tight tracking-[-0.04em] text-foreground sm:text-4xl md:text-5xl"
      >
        Formações
      </h2>
      <p
        class="mt-4 max-w-xl font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
      >
        Graduação, cursos e certificações
      </p>
    </Reveal>

    <ul
      class="mt-16 list-none space-y-0 border-t border-border lg:mt-20"
    >
      {
        formations.map((f, index) => (
          <li>
            <Reveal staggerMs={index * 80}>
              <article
                class:list={[
                  "border-b border-border py-10 last:border-b-0 md:py-12",
                ]}
              >
                <div class="flex flex-col gap-6 sm:flex-row sm:gap-8 lg:gap-10">
                  <div class="flex size-20 shrink-0 items-center justify-center rounded-md border border-neutral-200 bg-white sm:size-24">
                    <img
                      src={f.logo}
                      alt={`Logo ${f.institution}`}
                      width="80"
                      height="80"
                      class="max-h-[4.5rem] max-w-[4.5rem] object-contain p-2 sm:max-h-[5rem] sm:max-w-[5rem]"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="min-w-0 flex-1">
                    <h3
                      class:list={[
                        "font-display font-semibold leading-tight tracking-[-0.03em] text-foreground",
                        f.isSecondary
                          ? "text-lg md:text-xl"
                          : "text-xl md:text-2xl",
                      ]}
                    >
                      {f.title}
                    </h3>
                    <div class="mt-2 flex items-start justify-between gap-x-4 gap-y-1 font-mono text-sm">
                      <span class="min-w-0 flex-1 pr-2 text-accent">{f.institution}</span>
                      <span class="shrink-0 pt-px text-right text-xs uppercase tracking-[0.12em] text-muted-foreground">
                        {f.period}
                      </span>
                    </div>
                    {f.description && (
                      <p class="mt-4 max-w-2xl text-base leading-[1.6] text-muted-foreground md:leading-relaxed">
                        {f.description}
                      </p>
                    )}
                    {f.link && (
                      <p class="mt-5">
                        <a
                          href={f.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-mono text-xs font-medium uppercase tracking-[0.1em] text-accent underline decoration-2 underline-offset-4 transition-colors duration-150 hover:text-foreground focus-ring"
                        >
                          Ver credencial no Coursera
                        </a>
                      </p>
                    )}
                  </div>
                </div>
              </article>
            </Reveal>
          </li>
        ))
      }
    </ul>
  </Container>
</section>
