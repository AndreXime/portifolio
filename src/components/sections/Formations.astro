---
import Container from "../ui/Container.astro";
import AccentBar from "../ui/AccentBar.astro";
import Reveal from "../ui/Reveal.astro";
import { Image } from "astro:assets";
import { formations } from "../../content/index";

const formationItems = formations.map((formation, index) => ({
  formation,
  index,
}));
const showFormationsFooter = formations.some((f) => !f.featured);
---

<section
  id="formacoes"
  class="scroll-mt-20 border-b border-border bg-muted py-16 md:py-20 lg:py-24"
  aria-labelledby="form-heading"
>
  <Container>
    <div class="grid grid-cols-1 items-center gap-8 lg:grid-cols-12 lg:gap-10">
      <Reveal staggerMs={0} class="lg:col-span-5">
        <AccentBar class="mb-6" />
        <h2
          id="form-heading"
          class="font-display text-3xl font-semibold leading-tight tracking-tight text-foreground sm:text-4xl md:text-5xl"
        >
          Formações
        </h2>
        <p
          class="mt-4 font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
        >
          Graduação, cursos e certificações
        </p>
      </Reveal>
      <Reveal staggerMs={80} class="flex items-center lg:col-span-7">
        <p class="text-base leading-[1.7] text-foreground-variant md:text-lg">
          Graduação em andamento e cursos que reforçam a base técnica. O que
          aparece aqui é o que mais dialoga com o que entrego hoje.
        </p>
      </Reveal>
    </div>

    <div
      data-expandable-list
      data-scroll-section="formacoes"
      data-expand-label="Ver menos certificações"
      data-collapse-label="Ver mais certificações"
    >
      <ul class="mt-14 list-none border border-border bg-card lg:mt-16">
        {
          formationItems.map(({ formation, index }) => {
            const isExtra = !formation.featured;
            const { title, institution, period, logo, description, link } =
              formation;

            return (
              <li
                class:list={[
                  "border-b border-border last:border-b-0",
                  isExtra && "hidden",
                ]}
                data-expandable-extra={isExtra ? "" : undefined}
              >
                <Reveal staggerMs={index * 60}>
                  <article class="card-hover-flat group/card grid grid-cols-1 gap-6 p-6 md:p-8 sm:grid-cols-[auto_1fr] sm:gap-8">
                    <div class="flex size-16 shrink-0 items-center justify-center border border-border bg-muted transition-colors duration-150 group-hover/card:border-accent sm:size-20">
                      <Image
                        src={logo}
                        alt={`Logo ${institution}`}
                        format="webp"
                        width={80}
                        height={80}
                        sizes="80px"
                        class="max-h-12 max-w-12 object-contain p-2 sm:max-h-14 sm:max-w-14"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                    <div class="min-w-0">
                      <h3 class="card-hover-title font-display text-xl font-semibold leading-tight text-foreground md:text-2xl">
                        {title}
                      </h3>
                      <div class="mt-2 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
                        <span class="font-mono text-sm text-foreground-variant">
                          {institution}
                        </span>
                        <span class="font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground">
                          {period}
                        </span>
                      </div>
                      {description && (
                        <p class="mt-4 max-w-2xl text-base leading-[1.7] text-foreground-variant">
                          {description}
                        </p>
                      )}
                      {link && (
                        <p class="mt-5">
                          <a
                            href={link}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="font-mono text-xs font-medium uppercase tracking-[0.1em] text-accent underline decoration-accent/40 decoration-1 underline-offset-4 transition-colors duration-150 hover:decoration-accent focus-ring"
                          >
                            Ver credencial no Coursera
                          </a>
                        </p>
                      )}
                    </div>
                  </article>
                </Reveal>
              </li>
            );
          })
        }
      </ul>

      {
        showFormationsFooter && (
          <div class="mt-10 flex flex-col items-center justify-center gap-4 border-t border-border pt-10">
            <button
              type="button"
              class="inline-flex items-center justify-center border border-foreground px-5 py-3 font-mono text-xs font-medium uppercase tracking-[0.12em] text-foreground transition-colors duration-150 hover:bg-foreground hover:text-background focus-ring active:translate-y-px"
              data-expandable-show-more
              aria-expanded="false"
            >
              Ver mais certificações
            </button>
          </div>
        )
      }
    </div>
  </Container>
</section>
