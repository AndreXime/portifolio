---
import IconArrow from "./icons/IconArrow.astro";

interface Props {
  variant?: "primary" | "secondary" | "ghost";
  href?: string;
  type?: "button" | "submit";
  disabled?: boolean;
  class?: string;
  showArrow?: boolean;
  onLight?: boolean;
}

const {
  variant = "primary",
  href,
  type = "button",
  disabled = false,
  class: className = "",
  showArrow = false,
  onLight = false,
  ...rest
} = Astro.props;

const isHashLink =
  typeof href === "string" && (href.startsWith("#") || href.startsWith("/#"));

const hashTargetId = isHashLink ? href.split("#")[1] : undefined;

const Tag = isHashLink ? "button" : href ? "a" : "button";

const shared =
  "inline-flex cursor-pointer items-center justify-center gap-2 whitespace-nowrap rounded-none border font-mono text-xs font-medium uppercase tracking-[0.12em] transition-colors duration-150 ease-[cubic-bezier(0.25,0,0,1)] focus-ring active:translate-y-px disabled:pointer-events-none disabled:opacity-50";

function secondaryClass(light: boolean) {
  return light
    ? "border-background bg-transparent px-5 py-3 text-background hover:bg-background hover:text-foreground"
    : "border-foreground bg-transparent px-5 py-3 text-foreground hover:border-accent hover:bg-accent hover:text-accent-foreground";
}

function ghostClass(light: boolean) {
  return light
    ? "border-transparent px-4 py-3 text-background/70 hover:text-background"
    : "border-transparent px-4 py-3 text-muted-foreground hover:text-accent";
}

const variantClass: Record<NonNullable<typeof variant>, string> = {
  primary: onLight
    ? "border-background bg-background px-5 py-3 text-foreground hover:bg-transparent hover:text-background"
    : "border-accent bg-accent px-5 py-3 text-accent-foreground hover:bg-transparent hover:text-accent",
  secondary: secondaryClass(onLight),
  ghost: ghostClass(onLight),
};
---

<Tag
  {...rest}
  class:list={[shared, variantClass[variant], className]}
  href={Tag === "a" ? href : undefined}
  type={Tag === "button" ? (isHashLink ? "button" : type) : undefined}
  disabled={Tag === "button" ? disabled : undefined}
  data-scroll-to={isHashLink ? hashTargetId : undefined}
>
  <slot />
  {showArrow && <IconArrow class="size-3.5 shrink-0" />}
</Tag>
