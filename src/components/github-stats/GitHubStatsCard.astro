---
import Reveal from "../ui/Reveal.astro";
import { getCachedGitHubStats } from "./stats";

interface Props {
	class?: string;
	staggerMs?: number;
}

const { class: className, staggerMs = 120 } = Astro.props;

const stats = await getCachedGitHubStats();

function formatCount(value: number): string {
	return value.toLocaleString("pt-BR");
}

const activityMetrics = stats
	? [
			{ label: "Streak atual", value: formatCount(stats.streak.current) },
			{ label: "Maior streak", value: formatCount(stats.streak.longest) },
			{
				label: "Dias ativos",
				value: formatCount(stats.activity.activeDays),
			},
			{ label: "Commits", value: formatCount(stats.activity.commits) },
		]
	: [];
---

{
	stats && (
		<Reveal staggerMs={staggerMs} class={className}>
			<div class="border border-border bg-background/40 p-6 md:p-8">
				<p class="font-mono text-xs uppercase tracking-[0.15em] text-muted-foreground">
					Atividade no GitHub nos últimos 12 meses
				</p>

				<dl class="mt-6 grid grid-cols-2 gap-6">
					{activityMetrics.map((metric, index) => (
						<div>
							<dt class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted-foreground">
								{metric.label}
							</dt>
							<dd
								class:list={[
									"mt-1 font-display text-2xl font-semibold tracking-[-0.04em] text-foreground",
									index === 0 && "text-accent",
								]}
							>
								{metric.value}
							</dd>
						</div>
					))}
				</dl>

				<div class="mt-8 space-y-3 border-t border-border pt-6">
					<p class="font-mono text-[10px] uppercase tracking-[0.1em] text-muted-foreground">
						Linguagens nos meus repositórios
					</p>
					<ul
						class="list-none space-y-3"
						aria-label="Distribuição de linguagens"
					>
						{stats.languages.map((lang) => (
							<li>
								<div class="flex items-baseline justify-between gap-3 font-mono text-xs">
									<span class="text-foreground">
										{lang.name}
									</span>
									<span class="text-muted-foreground">
										{lang.percentage.toFixed(1)}%
									</span>
								</div>
								<div
									class="mt-1.5 h-1 w-full bg-border"
									role="presentation"
								>
									<div
										class="h-full transition-[width] duration-500 ease-[cubic-bezier(0.25,0,0,1)]"
										style={`width: ${lang.percentage}%; background-color: ${lang.color}`}
									/>
								</div>
							</li>
						))}
					</ul>
				</div>
			</div>
		</Reveal>
	)
}
