---
import Container from "../ui/Container.astro";
import IconGithub from "../ui/icons/IconGithub.astro";
import IconLinkedin from "../ui/icons/IconLinkedin.astro";
import { site } from "../../data/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-muted py-12 md:py-16">
  <Container>
    <div
      class="flex flex-col gap-10 sm:flex-row sm:items-center sm:justify-between lg:gap-16"
    >
      <div>
        <p
          class="font-mono text-xs uppercase tracking-[0.15em] text-muted-foreground"
        >
          Portfólio de {site.authorName}
        </p>
        <p class="mt-2 max-w-md text-sm leading-relaxed text-muted-foreground">
          Tipografia como linguagem — código como estrutura.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-6 sm:gap-8">
        <a
          href={site.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors duration-150 hover:text-accent focus-ring"
          aria-label="GitHub"
        >
          <IconGithub class="size-[18px]" />
        </a>
        <a
          href={site.linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted-foreground transition-colors duration-150 hover:text-accent focus-ring"
          aria-label="LinkedIn"
        >
          <IconLinkedin class="size-[18px]" />
        </a>
        <a
          href="#inicio"
          class="font-mono text-xs uppercase tracking-[0.1em] text-muted-foreground underline decoration-border decoration-2 underline-offset-4 transition-colors duration-150 hover:text-foreground hover:decoration-accent focus-ring"
        >
          Topo
        </a>
      </div>
    </div>

    <p
      class="mt-12 border-t border-border pt-8 font-mono text-xs text-muted-foreground"
    >
      © {year}
    </p>
  </Container>
</footer>
