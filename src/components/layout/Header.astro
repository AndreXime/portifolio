---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import IconMenu from "../ui/icons/IconMenu.astro";
import IconClose from "../ui/icons/IconClose.astro";
import { site } from "../../content/site";

const links = [
  { href: "#sobre", label: "Sobre" },
  { href: "#experiencias", label: "Experiências" },
  { href: "#projetos", label: "Projetos" },
  { href: "#tecnologias", label: "Tecnologias" },
  { href: "#formacoes", label: "Formações" },
  { href: "#contato", label: "Contato" },
] as const;
---

<header
  class="fixed top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-none"
>
  <Container element="div" class="flex items-center justify-between py-4 md:py-5">
    <button
      data-scroll-to="inicio"
      class="font-display cursor-pointer text-left text-lg font-semibold leading-none tracking-tight text-foreground focus-ring md:text-xl"
    >
      {site.authorName}
    </button>

    <nav
      class="hidden items-center gap-1 lg:flex"
      aria-label="Principal"
    >
      {
        links.map(({ href, label }) => (
          <Button
            variant="ghost"
            href={href}
            data-nav-section={href.slice(1)}
            class="px-2.5 py-1.5 font-mono text-[11px] !font-medium uppercase !tracking-[0.1em]"
          >
            {label}
          </Button>
        ))
      }
    </nav>

    <details class="group relative lg:hidden" id="nav-drawer">
      <summary
        class="flex size-11 cursor-pointer list-none items-center justify-center rounded-none border border-border bg-card text-foreground transition-colors duration-150 hover:border-border-hover [&::-webkit-details-marker]:hidden"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="nav-drawer-panel"
      >
        <IconMenu class="size-5 group-open:hidden" />
        <IconClose class="hidden size-5 group-open:block" />
      </summary>
      <div
        id="nav-drawer-panel"
        data-nav-drawer-panel
        class="absolute right-0 top-full z-50 mt-2 w-56 border border-border bg-card"
      >
        {
          links.map(({ href, label }) => (
            <a
              href={href}
              data-nav-section={href.slice(1)}
              class="block border-b border-border px-4 py-3 font-mono text-xs uppercase tracking-[0.1em] text-muted-foreground transition-colors duration-150 last:border-b-0 hover:bg-muted hover:text-foreground focus-ring"
            >
              {label}
            </a>
          ))
        }
      </div>
    </details>
  </Container>
</header>
