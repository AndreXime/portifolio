---
import Header from "../sections/Header.astro";
import Footer from "../sections/Footer.astro";
import Hero from "../sections/Hero.astro";
import About from "../sections/About.astro";
import Experiences from "../sections/Experiences.astro";
import Formations from "../sections/Formations.astro";
import Technologies from "../sections/Technologies.astro";
import Projects from "../sections/Projects.astro";
import Contact from "../sections/Contact.astro";
import CTA from "../sections/CTA.astro";
import Layout from "../../layouts/Layout.astro";
import { buildPortfolioJsonLd } from "../../lib/portfolio-json-ld";
import { getHomePageContent } from "../../lib/i18n/context";

const {
  locale,
  ui,
  site,
  experiences,
  projects,
  formations,
  technologies,
} = await getHomePageContent(Astro.currentLocale);

const siteOrigin = new URL("/", Astro.site).origin;
const jsonLdLabels = {
  websiteName: ui.jsonLd.websiteName,
  home: ui.projectPage.home,
  projects: ui.projects.title,
};
const jsonLd = buildPortfolioJsonLd({
  site: siteOrigin,
  locale,
  labels: jsonLdLabels,
  seo: site.seo,
  person: site.person,
  githubUrl: site.githubUrl,
  linkedinUrl: site.linkedinUrl,
  experiences,
  projects: projects.map((project) => ({
    ...project,
    id: project.slug,
  })),
});
---

<Layout
  locale={locale}
  site={site}
  title={site.seo.title}
  description={site.seo.description}
  jsonLd={jsonLd}
>
  <Header />
  <main>
    <Hero />
    <About />
    <Experiences experiences={experiences} />
    <Projects projects={projects} />
    <Technologies technologies={technologies} />
    <Formations formations={formations} />
    <Contact />
    <CTA />
  </main>
  <Footer />
  <script>
    import { initContactForm } from "../../scripts/contact-form";
    import { initExpandableList } from "../../scripts/expandable-list";
    import { initNavScrollSpy } from "../../scripts/nav-scroll-spy";
    import { initReveal } from "../../scripts/reveal-observer";

    function initHomePage(): void {
      initReveal();
      initNavScrollSpy();
      initExpandableList();
      initContactForm();
    }

    document.addEventListener("DOMContentLoaded", initHomePage);
  </script>
</Layout>
