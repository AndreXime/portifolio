---
import Analytics from "@vercel/analytics/astro";
import { aboveTheFoldFontPreloads } from "../styles/fonts";
import { experiences, projects, site } from "../content/index";
import { buildPortfolioJsonLd } from "../lib/portfolio-json-ld";

interface Props {
  robots?: string;
  title?: string;
  description?: string;
  ogImageAlt?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteOrigin = new URL("/", Astro.site).origin;

const {
  robots = "index, follow",
  title = site.seo.title,
  description = site.seo.description,
  ogImageAlt = site.seo.ogImageAlt,
  ogImage = "/og-image.png",
  jsonLd = buildPortfolioJsonLd({
    site: siteOrigin,
    seo: site.seo,
    person: site.person,
    githubUrl: site.githubUrl,
    linkedinUrl: site.linkedinUrl,
    experiences,
    projects,
  }),
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.site);
const schema = JSON.stringify(jsonLd);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      aboveTheFoldFontPreloads.map((href) => (
        <link
          rel="preload"
          href={href}
          as="font"
          type="font/woff2"
          crossorigin="anonymous"
        />
      ))
    }
    <script is:inline defer type="application/ld+json" set:html={schema} />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content={robots} />
    <meta name="author" content={site.person.fullName} />
    <meta name="apple-mobile-web-app-title" content="André Portifolio" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={site.seo.title} />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <Analytics />
  </head>
  <body class="min-h-screen overflow-x-clip pt-0">
    <slot />
  </body>
</html>
