---
import Analytics from "@vercel/analytics/astro";
import { aboveTheFoldFontPreloads } from "../styles/fonts";
import { getSite, type SiteContent } from "../content/index";
import {
  defaultLocale,
  htmlLang,
  ogLocale,
  resolveLocale,
  type Locale,
} from "../i18n";
import { absoluteLocaleUrl, stripLocalePrefix } from "../i18n/paths";

interface Props {
  robots?: string;
  title?: string;
  description?: string;
  ogImageAlt?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
  locale?: Locale;
  site?: SiteContent;
}

const locale = resolveLocale(Astro.props.locale ?? Astro.currentLocale);
const siteContent = Astro.props.site ?? (await getSite(locale));

const barePath = stripLocalePrefix(Astro.url.pathname);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const ptAlternate = absoluteLocaleUrl("pt", barePath);
const enAlternate = absoluteLocaleUrl("en", barePath);
const xDefault = absoluteLocaleUrl(defaultLocale, barePath);

const {
  robots = "index, follow",
  title = siteContent.seo.title,
  description = siteContent.seo.description,
  ogImageAlt = siteContent.seo.ogImageAlt,
  ogImage = "/og-image.png",
  jsonLd = {},
} = Astro.props;

const showAnalytics = import.meta.env.ASTRO_NODE !== "1";
const socialImageURL = new URL(ogImage, Astro.site);
const schema = JSON.stringify(jsonLd);
---

<!doctype html>
<html lang={htmlLang(locale)}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      aboveTheFoldFontPreloads.map((href) => (
        <link
          rel="preload"
          href={href}
          as="font"
          type="font/woff2"
          crossorigin="anonymous"
        />
      ))
    }
    <script is:inline defer type="application/ld+json" set:html={schema} />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="pt" href={ptAlternate} />
    <link rel="alternate" hreflang="en" href={enAlternate} />
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <meta name="robots" content={robots} />
    <meta name="author" content={siteContent.person.fullName} />
    <meta name="apple-mobile-web-app-title" content="André Portifolio" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={siteContent.seo.title} />
    <meta property="og:locale" content={ogLocale(locale)} />
    <meta
      property="og:locale:alternate"
      content={locale === "pt" ? ogLocale("en") : ogLocale("pt")}
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {showAnalytics ? <Analytics /> : null}
  </head>
  <body class="min-h-screen overflow-x-clip pt-0">
    <slot />
  </body>
</html>
