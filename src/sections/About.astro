---
import {
  Code2,
  Coffee,
  Globe,
  User,
  GraduationCap,
  Briefcase,
  BookOpenText,
} from "lucide-preact";
import SectionHeader from "../components/ui/SectionHeader";
import { Sobre, Experiencias, Formação, Certificados } from "../content/about";
import { optimizeCompactImage } from "@/lib/optimizeImages";
---

<section
  id="sobre"
  class="py-24 bg-bgSectionAlt border-y border-border/60 relative overflow-hidden"
>
  <div
    class="absolute top-0 left-1/4 w-64 h-64 bg-primary/5 rounded-full blur-3xl -z-10"
  >
  </div>
  <div
    class="absolute bottom-0 right-1/4 w-96 h-96 bg-secondary/5 rounded-full blur-3xl -z-10"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-reveal-time={0} class="reveal reveal-hidden">
      <SectionHeader
        bagde="Me conheça"
        title="Sobre mim"
        subtitle="Minha trajetória: da base acadêmica à experiência prática e minha visão de desenvolvedor."
      />

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-16">
        <div
          class="lg:col-span-8 bg-surface p-8 md:p-10 rounded-3xl border border-border/60 shadow-sm hover:shadow-md transition-shadow"
        >
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2.5 bg-primary/10 rounded-xl text-primary">
              <User class="w-6 h-6" aria-hidden="true" />
            </div>
            <h3 class="text-2xl font-bold text-textSecondary">
              Minha Trajetória
            </h3>
          </div>

          <div class="space-y-6 text-textMuted leading-relaxed">
            {Sobre.Trajetoria.split("\n").map((p) => <p set:html={p} />)}
          </div>
        </div>

        <div class="lg:col-span-4 grid grid-cols-1 gap-4">
          <div
            class="bg-secondary p-6 rounded-3xl text-white shadow-lg shadow-secondary/20"
          >
            <Code2 class="w-8 h-8 mb-2" aria-hidden="true" />
            <p class="text-white/80 text-sm font-medium">Stack Principal</p>
            <p class="text-xl font-bold">{Sobre.Destaques.Stack}</p>
          </div>

          <div
            class="bg-surface p-6 rounded-3xl border border-border/60 flex items-center gap-4"
          >
            <div class="p-3 bg-error/10 rounded-2xl text-error">
              <Coffee class="w-6 h-6" aria-hidden="true" />
            </div>
            <div>
              <p class="text-sm text-textMuted">Experiência</p>
              <p class="font-bold text-textSecondary text-lg">
                {Sobre.Destaques.Experiência}
              </p>
            </div>
          </div>

          <div
            class="bg-surface p-6 rounded-3xl border border-border/60 flex items-center gap-4"
          >
            <div class="p-3 bg-success/10 rounded-2xl text-success">
              <Globe class="w-6 h-6" aria-hidden="true" />
            </div>
            <div>
              <p class="text-sm text-textMuted">Localização</p>
              <p class="font-bold text-textSecondary text-lg">
                {Sobre.Destaques.Localização}
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-8">
        <div class="space-y-6">
          <div class="flex items-center gap-3 px-2">
            <Briefcase class="w-6 h-6 text-primary" aria-hidden="true" />
            <h3 class="text-2xl font-bold text-textMain">Experiência</h3>
          </div>

          <div class="relative pl-6 border-l-2 border-border/40 space-y-8">
            {
              Experiencias.map(async (exp) => {
                const imageUrl = await optimizeCompactImage(exp.ImageUrl);

                return (
                  <div class="relative">
                    <div class="absolute -left-[33px] top-1 w-4 h-4 rounded-full border-4 border-surface bg-primary shadow-sm" />
                    <div class="bg-surface px-6 py-5 rounded-2xl border border-border/60 hover:border-primary/30 transition-colors shadow-sm">
                      <div class="flex gap-6 items-center">
                        <div class="size-12 flex-shrink-0 rounded-full overflow-hidden bg-white flex items-center justify-center p-1">
                          <img
                            src={imageUrl}
                            alt="Logo da stackup"
                            width={48}
                            height={48}
                            class="w-full h-full object-contain"
                          />
                        </div>
                        <div>
                          <span class="text-primary font-mono text-xs font-bold uppercase tracking-wider">
                            {exp.Periodo}
                          </span>
                          <h4 class="text-xl font-bold text-textSecondary">
                            {exp.Cargo}
                          </h4>
                          <p class="text-textMuted font-medium flex items-center gap-2">
                            {exp.Empresa}
                          </p>
                        </div>
                      </div>
                      <div
                        class="text-textMuted text-sm leading-relaxed mt-3"
                        set:html={exp.Descrição}
                      />
                    </div>
                  </div>
                );
              })
            }
          </div>
        </div>
        <div class="grid lg:grid-cols-2 gap-8">
          <div class="space-y-6">
            <div class="flex items-center gap-3 px-2">
              <GraduationCap class="w-6 h-6 text-primary" aria-hidden="true" />
              <h3 class="text-2xl font-bold text-textMain">Formação</h3>
            </div>

            <div class="relative pl-6 border-l-2 border-border/40 space-y-8">
              {
                Formação.map(async (edu) => {
                  const imageUrl = await optimizeCompactImage(edu.ImageUrl);

                  return (
                    <div>
                      <div class="bg-surface px-6 py-5 rounded-2xl border border-border/60 hover:border-primary/30 transition-colors">
                        <div class="flex gap-6 items-center">
                          <div class="size-12 flex-shrink-0 rounded-full overflow-hidden bg-white flex items-center justify-center p-1">
                            <img
                              src={imageUrl}
                              alt="Logo da universidades"
                              width={50}
                              height={50}
                              class="w-full h-full object-contain"
                            />
                          </div>
                          <div>
                            <span class="text-primary font-mono text-xs font-bold uppercase tracking-wider">
                              {edu.Periodo}
                            </span>
                            <h4 class="text-xl font-bold text-textSecondary">
                              {edu.Curso}
                            </h4>
                            <p class="text-textMuted font-medium">
                              {edu.Instituição}
                            </p>
                          </div>
                        </div>
                        <p
                          class="text-textMuted text-sm leading-relaxed mt-3"
                          set:html={edu.Descrição}
                        />
                      </div>
                    </div>
                  );
                })
              }
            </div>
          </div>
          <div class="space-y-6">
            <div class="flex items-center gap-3 px-2">
              <BookOpenText class="w-6 h-6 text-primary" aria-hidden="true" />
              <h3 class="text-2xl font-bold text-textMain">Certificados</h3>
            </div>

            <div class="relative pl-6 border-l-2 border-border/40 space-y-8">
              {
                Certificados.map(async (cert) => {
                  const imageUrl = await optimizeCompactImage(cert.Logo);

                  return (
                    <div>
                      <div class="bg-surface px-6 py-5 rounded-2xl border border-border/60 hover:border-primary/30 transition-colors">
                        <div class="flex gap-6 items-center">
                          <div class="size-12 flex-shrink-0 rounded-full overflow-hidden bg-white flex items-center justify-center p-1">
                            <img
                              src={imageUrl}
                              alt="Logo da universidades"
                              width={50}
                              height={50}
                              class="w-full h-full object-contain"
                            />
                          </div>
                          <div>
                            <span class="text-primary font-mono text-xs font-bold uppercase tracking-wider">
                              {cert.Data}
                            </span>
                            <a href={cert.Link}>
                              <h4 class="text-md font-bold text-textSecondary underline">
                                {cert.Nome}
                              </h4>
                            </a>
                            <p class="text-textMuted font-medium">
                              {cert.Instituição} - {cert.Plataforma}
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                  );
                })
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
