---
import { Github, Linkedin } from "lucide-preact";
import { Links, Hero as HeroText } from "../content/about";
import Code from "../components/CodeSnippet/Code.astro";
---

<section id="home" class="pt-35 pb-25 lg:py-70 flex items-center bg-bgSection">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <div
          class="mb-4 font-medium inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/30 bg-primary/5 text-sm text-primary"
        >
          <span
            class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"
          ></span>
          <span>Disponível para novas oportunidades</span>
        </div>
        <p class="text-lg text-textMuted mb-2 font-medium">Olá, meu nome é</p>
        <h1
          class="text-5xl sm:text-7xl font-bold mb-2 leading-tight text-textMain tracking-tight"
        >
          André Ximenes
        </h1>
        <h2
          class="text-2xl sm:text-3xl text-textSecondary mb-8 font-medium leading-snug"
        >
          Desenvolvedor de software especializado em
          <span
            id="hero-focus"
            class="text-primary font-bold transition-all duration-300 ease-out"
          >
            TypeScript</span
          >.
        </h2>

        <p
          class="text-lg text-textMuted mb-8 max-w-lg leading-relaxed border-l-4 border-primary/20 pl-4"
        >
          {HeroText}
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="#contato"
            class="mr-4 px-6 py-3 bg-primaryDark text-white rounded-lg font-medium hover:bg-primary transition-all flex items-center gap-2"
          >
            Entrar em contato
          </a>

          <div class="flex gap-4">
            <a
              href={Links.Github}
              target="_blank"
              rel="noreferrer"
              aria-label="Visitar meu perfil no GitHub"
              class="w-11 h-11 flex items-center justify-center text-textMuted hover:text-primary transition-colors"
            >
              <Github aria-hidden="true" />
            </a>

            <a
              href={Links.Linkedin}
              target="_blank"
              rel="noreferrer"
              aria-label="Visitar meu perfil no LinkedIn"
              class="w-11 h-11 flex items-center justify-center text-textMuted hover:text-primary transition-colors"
            >
              <Linkedin aria-hidden="true" />
            </a>
          </div>
        </div>
      </div>

      <div class="relative lg:block group perspective-[1000px] h-full">
        <div class="relative h-full">
          <Code />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function setupHighlights() {
    const labels = [
      "TypeScript",
      "UX/UI",
      "APIs RESTful",
      "Arquitetura modulares",
    ];
    const el = document.querySelector("#hero-focus");

    if (el) {
      let index = 0;

      setInterval(() => {
        index = (index + 1) % labels.length;

        el.classList.add("opacity-0", "translate-y-1");

        setTimeout(() => {
          el.textContent = labels[index];
          el.classList.remove("translate-y-1");
          el.classList.remove("opacity-0");
        }, 150);
      }, 2500);
    }
  }
  setupHighlights();
</script>
