---
import "../styles/global.css";
import LinkifiedText from "../components/ui/LinkifiedText.astro";
import {
    experiences,
    formations,
    projects,
    site,
    technologies,
} from "../content/index";

function stripHtml(html: string): string {
    return html.replace(/<[^>]*>/g, "");
}

function absoluteUrl(path: string): string {
    if (path.startsWith("http")) return path;
    return new URL(path, Astro.site).href;
}

interface ClipboardItem {
    id: string;
    label: string;
    text: string;
}

type PageSection =
    | { kind: "items"; label: string; items: ClipboardItem[] }
    | { kind: "block"; label: string; id: string; text: string };

const contactItems: ClipboardItem[] = [
    { id: "contato-nome", label: "Nome", text: site.person.fullName },
    { id: "contato-cargo", label: "Cargo", text: site.person.jobTitle },
    { id: "contato-email", label: "E-mail", text: site.email },
    { id: "contato-linkedin", label: "LinkedIn", text: site.linkedinUrl },
    { id: "contato-github", label: "GitHub", text: site.githubUrl },
    {
        id: "contato-cv",
        label: "CV",
        text: absoluteUrl(site.resumePdfUrl),
    },
];

const aboutText = site.about.paragraphs.map(stripHtml).join("\n\n");

const pitchText = ["Olá meu nome é André Ximenes. ", site.hero.intro].join("");

const stackText = technologies
    .map((tech) => tech.name.replace(/ e /g, ", "))
    .join(", ");

const experienceBlocks = experiences.map((exp) => {
    const lines = [
        `${exp.role} — ${exp.company} (${exp.period})`,
        "",
        exp.summary,
    ];
    if (exp.highlights?.length) {
        lines.push("", ...exp.highlights.map((item) => `• ${item}`));
    }
    return lines.join("\n");
});

const experienceText = experienceBlocks.join("\n\n—\n\n");

const formationItems: ClipboardItem[] = formations.map((item, index) => {
    const lines = [`${item.title} — ${item.institution} (${item.period})`];
    if (item.description) lines.push(item.description);
    if (item.link) lines.push(item.link);
    return {
        id: `formacao-${index}`,
        label: item.title,
        text: lines.join("\n"),
    };
});

const projectItems: ClipboardItem[] = projects.map((project) => {
    const { data } = project;
    const lines = [
        data.title,
        "",
        data.shortDescription,
        "",
        `Stack: ${data.tech.join(", ")}`,
    ];
    if (data.link) lines.push(`Demo: ${data.link}`);
    lines.push(`GitHub: ${data.github}`);
    return {
        id: `projeto-${project.id}`,
        label: data.title,
        text: lines.join("\n"),
    };
});

const pageSections: PageSection[] = [
    { kind: "items", label: "Contato", items: contactItems },
    { kind: "block", label: "Pitch", id: "pitch", text: pitchText },
    { kind: "block", label: "Sobre", id: "sobre", text: aboutText },
    { kind: "block", label: "Stack", id: "stack", text: stackText },
    {
        kind: "block",
        label: "Experiência",
        id: "experiencia",
        text: experienceText,
    },
    { kind: "items", label: "Formação", items: formationItems },
    { kind: "items", label: "Projetos", items: projectItems },
];

function sectionToText(section: PageSection): string {
    if (section.kind === "items") {
        return section.items
            .map((item) => `${item.label}\n${item.text}`)
            .join("\n\n");
    }
    return section.text;
}

const allText = pageSections
    .map((section) => `## ${section.label}\n\n${sectionToText(section)}`)
    .join("\n\n\n");

const actionClass =
    "inline-flex items-center border border-border bg-card px-2.5 py-1.5 font-mono text-[11px] text-foreground transition-colors duration-150 hover:border-border-hover focus-ring";

const copyClass =
    "inline-flex items-center border border-accent bg-accent px-2.5 py-1.5 font-mono text-[11px] text-accent-foreground transition-colors duration-150 hover:bg-transparent hover:text-accent focus-ring";
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex, nofollow" />
        <title>Clipboard · {site.authorName}</title>
    </head>
    <body
        class="min-h-screen bg-muted px-4 py-6 pb-12 font-mono text-[13px] leading-relaxed text-foreground"
    >
        <div class="mx-auto max-w-4xl">
            <header
                class="mb-8 flex flex-wrap items-baseline justify-between gap-x-4 gap-y-3 border-b border-border pb-4"
            >
                <div>
                    <h1 class="text-sm font-semibold">{site.authorName}</h1>
                    <p class="mt-1 text-xs text-muted-foreground">
                        Blocos de texto para copiar e colar
                    </p>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a href="/" class={actionClass}>Ver Portfólio Principal</a>
                    <button type="button" class={copyClass} data-copy="tudo">
                        Copiar tudo
                    </button>
                </div>
            </header>

            {
                pageSections.map((section) =>
                    section.kind === "items" ? (
                        <section class="mb-7">
                            <h2 class="mb-3 text-sm font-semibold uppercase tracking-[0.06em] text-muted-foreground">
                                {section.label}
                            </h2>
                            <div class="space-y-2">
                                {section.items.map((item) => (
                                    <div class="flex items-start justify-between gap-4 border border-border bg-card p-3">
                                        <div class="min-w-0 flex-1">
                                            <p class="text-[11px] font-semibold uppercase tracking-[0.06em] text-muted-foreground">
                                                {item.label}
                                            </p>
                                            <LinkifiedText
                                                id={item.id}
                                                text={item.text}
                                                class="mt-1"
                                            />
                                        </div>
                                        <button
                                            type="button"
                                            class={`${copyClass} shrink-0`}
                                            data-copy={item.id}
                                        >
                                            Copiar
                                        </button>
                                    </div>
                                ))}
                            </div>
                        </section>
                    ) : (
                        <section class="mb-7">
                            <div class="mb-2 flex items-center justify-between gap-4">
                                <h2 class="text-sm font-semibold uppercase tracking-[0.06em] text-muted-foreground">
                                    {section.label}
                                </h2>
                                <button
                                    type="button"
                                    class={copyClass}
                                    data-copy={section.id}
                                >
                                    Copiar
                                </button>
                            </div>
                            <LinkifiedText
                                id={section.id}
                                text={section.text}
                                class="border border-border bg-card p-3"
                            />
                        </section>
                    ),
                )
            }

            <pre id="tudo" hidden set:text={allText} />
        </div>

        <script>
            const copiedClass = ["bg-transparent", "text-accent"];

            for (const button of document.querySelectorAll("[data-copy]")) {
                button.addEventListener("click", async () => {
                    const targetId = button.getAttribute("data-copy");
                    if (!targetId) return;

                    const target = document.getElementById(targetId);
                    if (!target) return;

                    await navigator.clipboard.writeText(
                        target.dataset.copyText ?? target.textContent ?? "",
                    );

                    const label = button.textContent;
                    button.textContent = "Copiado";
                    button.classList.add(...copiedClass);
                    button.classList.remove(
                        "bg-accent",
                        "text-accent-foreground",
                    );

                    window.setTimeout(() => {
                        button.textContent = label;
                        button.classList.remove(...copiedClass);
                        button.classList.add(
                            "bg-accent",
                            "text-accent-foreground",
                        );
                    }, 1400);
                });
            }
        </script>
    </body>
</html>
