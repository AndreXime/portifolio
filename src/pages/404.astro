---
import MainLayout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { getSite } from "../content/index";
import { resolveLocale, t } from "../locales";
import { localizedPath } from "../lib/i18n/paths";
import "../styles/global.css";

const locale = resolveLocale(Astro.currentLocale);
const ui = t(locale);
const site = await getSite(locale);
---

<MainLayout robots="noindex, nofollow" locale={locale} site={site}>
  <main class="flex min-h-screen items-center border-b border-border bg-background py-24">
    <Container>
      <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground">
        {ui.notFound.code}
      </p>
      <h1
        class="mt-6 font-display text-6xl font-semibold leading-none tracking-tight text-foreground md:text-8xl"
      >
        {ui.notFound.title}
      </h1>
      <p class="mt-6 max-w-lg text-base leading-[1.7] text-foreground-variant md:text-lg">
        {ui.notFound.body}
      </p>
      <div class="mt-10">
        <Button href={localizedPath(locale, "/")} variant="primary" showArrow>
          {ui.notFound.cta}
        </Button>
      </div>
    </Container>
  </main>
</MainLayout>
