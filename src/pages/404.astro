---
import MainLayout from "@/layouts/Layout.astro";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import "../styles/global.css";
---

<MainLayout>
  <main class="flex min-h-screen items-center border-b border-border bg-background py-24">
    <Container>
      <p class="font-mono text-[11px] uppercase tracking-[0.12em] text-muted-foreground">
        Erro 404
      </p>
      <h1
        class="mt-6 font-display text-6xl font-semibold leading-none tracking-tight text-foreground md:text-8xl"
      >
        Página não encontrada
      </h1>
      <p class="mt-6 max-w-lg text-base leading-[1.7] text-foreground-variant md:text-lg">
        A URL que você acessou não existe ou foi movida. Volte ao início do
        portfólio para continuar navegando.
      </p>
      <div class="mt-10">
        <Button href="/" variant="primary" showArrow>
          Ir ao início
        </Button>
      </div>
    </Container>
  </main>
</MainLayout>
