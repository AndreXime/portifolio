---
import "../../styles/fonts";
import "../../styles/global.css";
import { getSite } from "../../lib/content";
import { t } from "../../locales";
import AccentBar from "../../components/ui/AccentBar.astro";
import Container from "../../components/ui/Container.astro";

const ui = t("pt");
const site = await getSite("pt");
const { hero } = site;
const headlineParts = hero.headline.split(hero.headlineAccent);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <style is:inline>
      html,
      body {
        margin: 0;
        padding: 0;
        width: 1200px;
        height: 630px;
        overflow: hidden;
        box-sizing: border-box;
      }
    </style>
  </head>
  <body class="bg-background antialiased">
    <section class="h-full">
      <Container class="flex h-full flex-col justify-between py-8">
        <div>
          <p
            class="font-mono text-sm uppercase tracking-[0.14em] text-muted-foreground"
          >
            {site.person.jobTitle} · {ui.ogImage.portfolioLabel}
          </p>
          <AccentBar class="my-5" />
          <h1
            class="font-display max-w-2xl text-5xl font-semibold leading-[1.1] tracking-tight text-foreground"
          >
            {headlineParts[0]}
            <em
              class="text-accent not-italic underline decoration-accent decoration-2 underline-offset-[0.12em]"
            >
              {hero.headlineAccent}
            </em>
            {headlineParts[1]}
          </h1>

          <p
            class="mt-5 max-w-4xl py-5 text-xl leading-[1.6] text-foreground-variant"
          >
            Olá, sou <span class="font-semibold text-foreground"
              >{site.authorName}</span
            >. {site.person.description}
            {hero.intro}
          </p>
        </div>

        <dl class="grid grid-cols-4 gap-6 border-t border-border pt-8">
          <div>
            <dt
              class="font-mono text-sm uppercase tracking-[0.12em] text-muted-foreground"
            >
              Stack
            </dt>
            <dd class="mt-2 font-mono text-base text-foreground">
              {hero.stackLine}
            </dd>
          </div>
          <div>
            <dt
              class="font-mono text-sm uppercase tracking-[0.12em] text-muted-foreground"
            >
              {hero.availabilityLabel}
            </dt>
            <dd class="mt-2 font-mono text-base text-foreground">
              {hero.availabilityValue}
            </dd>
          </div>
          <div>
            <dt
              class="font-mono text-sm uppercase tracking-[0.12em] text-muted-foreground"
            >
              Localização
            </dt>
            <dd class="mt-2 font-mono text-base text-foreground">
              {hero.locationValue}
            </dd>
          </div>
          <div>
            <dt
              class="font-mono text-xs uppercase tracking-[0.12em] text-muted-foreground"
            >
              Contato
            </dt>
            <dd class="mt-2 font-mono text-sm text-foreground">
              {site.email}
            </dd>
          </div>
        </dl>
      </Container>
    </section>
  </body>
</html>
