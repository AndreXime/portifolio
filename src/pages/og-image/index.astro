---
import "../../styles/fonts";
import "../../styles/global.css";
import { site } from "../../content/site";
import AccentBar from "../../components/ui/AccentBar.astro";
import Container from "../../components/ui/Container.astro";
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="utf-8" />
        <meta name="robots" content="noindex" />
        <style is:inline>
            html,
            body {
                margin: 0;
                padding: 0;
                width: 1200px;
                height: 630px;
                overflow: hidden;
                box-sizing: border-box;
            }
        </style>
    </head>
    <body class="bg-background antialiased">
        <section class="h-full">
            <Container
                class="relative flex h-full flex-col justify-between py-14"
            >
                <div>
                    <AccentBar class="mb-8" />
                    <h1
                        class="font-display text-7xl font-semibold leading-[1.05] tracking-[-0.06em] text-foreground"
                    >
                        Construindo <span class="text-accent">APIs</span> eficientes,
                        seguras e fáceis de manter.
                    </h1>

                    <p
                        class="mt-8 max-w-2xl text-[1.35rem] leading-relaxed text-foreground"
                    >
                        <span class="font-semibold text-accent"
                            >{site.authorName}</span
                        >
                        {", "}
                        {site.person.jobTitle.toLowerCase()}. APIs com NestJS, Hono
                        e Node.js.{" "}
                        <span class="font-semibold text-accent"
                            >andreximenes.xyz</span
                        >
                    </p>
                </div>

                <dl
                    class="mt-10 grid grid-cols-3 gap-8 border-t border-border pt-12"
                >
                    <div>
                        <dt
                            class="font-mono uppercase tracking-[0.15em] text-muted-foreground"
                        >
                            Stack
                        </dt>
                        <dd class="mt-2 font-mono text-foreground">
                            {site.hero.stackLine}
                        </dd>
                    </div>
                    <div>
                        <dt
                            class="font-mono uppercase tracking-[0.15em] text-muted-foreground"
                        >
                            {site.hero.availabilityLabel}
                        </dt>
                        <dd class="mt-2 font-mono text-foreground">
                            {site.hero.availabilityValue}
                        </dd>
                    </div>
                    <div>
                        <dt
                            class="font-mono uppercase tracking-[0.15em] text-muted-foreground"
                        >
                            Localização
                        </dt>
                        <dd class="mt-2 font-mono text-foreground">
                            {site.hero.locationValue}
                        </dd>
                    </div>
                </dl>
            </Container>
        </section>
    </body>
</html>
